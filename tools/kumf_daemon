# ============================================================
# Main
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        prog="kumf daemon",
        description="KUMF daemon — transparent NUMA optimization"
    )
    sub = parser.add_subparsers(dest="daemon_cmd")

    # start
    p_start = sub.add_parser("start", help="Start the KUMF daemon")
    p_start.add_argument("--foreground", "-f", action="store_true", help="Run in foreground")
    p_start.add_argument("--socket", default=DEFAULT_SOCK, help="Unix socket path")

    # stop
    sub.add_parser("stop", help="Stop the KUMF daemon")

    # status
    sub.add_parser("status", help="Show daemon status")

    # wrap
    p_wrap = sub.add_parser("wrap", help="Wrap a command with KUMF optimization")
    p_wrap.add_argument("command", nargs=argparse.REMAINDER, help="Command to wrap")

    # profile
    p_prof = sub.add_parser("profile", help="Profile workload and generate config")
    p_prof.add_argument("--min-lat", type=int, default=32, help="SPE min latency filter (cycles, default 32)")
    p_prof.add_argument("--period", type=int, default=0, help="SPE sampling period (default: every event, 1000=1/1000th)")
    p_prof.add_argument("--user-only", action="store_true", help="Only sample user-space (EL0), ignore kernel")
    p_prof.add_argument("-o", "--output", default=None, help="Output directory")
    p_prof.add_argument("command", nargs=argparse.REMAINDER, help="Command to profile")

    # config
    sub.add_parser("config", help="Show auto-detected optimal config")

    # autostart
    sub.add_parser("autostart", help="Start daemon if not running (for shell rc)")

    # shell-init
    sub.add_parser("shell-init", help="Print shell integration snippets")

    args = parser.parse_args()

    daemon = KumfDaemon()

    if args.daemon_cmd == "start":
        return daemon.start(foreground=args.foreground)
    elif args.daemon_cmd == "stop":
        return daemon.stop()
    elif args.daemon_cmd == "status":
        return daemon.status()
    elif args.daemon_cmd == "wrap":
        cmd = args.command
        if cmd and cmd[0] == "--":
            cmd = cmd[1:]
        if not cmd:
            print("Error: no command specified", file=sys.stderr)
            return 1
        return daemon.wrap(cmd)
    elif args.daemon_cmd == "profile":
        cmd = args.command
        if cmd and cmd[0] == "--":
            cmd = cmd[1:]
        if not cmd:
            print("Error: no command specified", file=sys.stderr)
            return 1
        return daemon.profile(cmd, min_lat=args.min_lat, period=args.period,
                             user_only=args.user_only, output_dir=args.output)
    elif args.daemon_cmd == "config":
        topology = detect_numa_topology()
        config = get_optimal_config(topology)
        print("Auto-detected KUMF configuration:")
        for k, v in config.items():
            print(f"  {k}={v}")
        print()
        print(f"NUMA topology: {len(topology['nodes'])} nodes, {len(topology.get('sockets', []))} sockets")
        if topology.get("sockets"):
            print(f"Socket layout: {topology['sockets']}")
            print(f"Recommended: use socket 0 (nodes {topology['sockets'][0]}) for maximum stability")
        return 0
    elif args.daemon_cmd == "autostart":
        if not daemon._is_running():
            daemon.start(foreground=False)
        return 0
    elif args.daemon_cmd == "shell-init":
        print_shell_integration()
        return 0
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    sys.exit(main())
