#!/usr/bin/env python3
"""
kumf daemon — Transparent NUMA optimization daemon

Runs as a background service that:
1. Auto-detects NUMA topology on startup
2. Provides LD_PRELOAD injection for any process (via kumf wrap)
3. Can auto-profile workloads and generate optimal config
4. Monitors running processes and adjusts affinity dynamically

Usage:
  kumf daemon start [--foreground] [--socket PATH]
  kumf daemon stop
  kumf daemon status
  kumf daemon wrap [-- CMD...]
  kumf daemon profile -- CMD...
  kumf daemon config
"""

import os
import sys
import json
import time
import socket
import signal
import subprocess
import argparse
import threading
import hashlib
from pathlib import Path
from datetime import datetime

# ─── Path resolution: source tree vs installed ───
# Source tree:  KUMF/tools/kumf_daemon → KUMF/build/ (libs) + KUMF/tools/ (scripts)
# Installed:    /usr/local/lib/kumf/kumf_daemon → same dir for everything
# Bin symlinks: /usr/local/bin/kumf → ../lib/kumf/kumf (resolved by realpath)

def _resolve_kumf_dirs():
    """Find KUMF library and script directories.
    
    Symlink-safe: uses os.path.realpath() to resolve bin symlinks
    to the actual install directory.
    """
    env_home = os.environ.get("KUMF_HOME")
    if env_home:
        return Path(env_home), Path(env_home)

    # Real path resolves symlinks — e.g. /usr/local/bin/kumf_daemon → .../lib/kumf/kumf_daemon
    kdir = Path(os.path.realpath(__file__)).parent

    # Source tree detection: kdir = KUMF/tools/, parent/build/ = KUMF/build/
    # (NOT parent.parent, so /usr/local/build/ cannot interfere)
    if (kdir.parent / "build").is_dir():
        return kdir.parent / "build", kdir

    # Installed: everything in one directory
    return kdir, kdir

_LIB_DIR, _SHARE_DIR = _resolve_kumf_dirs()

INTERC_SO = _LIB_DIR / "libkumf_interc.so"
PROF_SO = _LIB_DIR / "libkumf_prof.so"
MLOCK_SO = _LIB_DIR / "libkumf_mlock.so"
DEFAULT_SOCK = "/tmp/kumf_daemon.sock"
DEFAULT_PID_FILE = "/tmp/kumf_daemon.pid"
DEFAULT_STATE_DIR = Path("/tmp/kumf_daemon")
SPE_PAGE_PAC = _SHARE_DIR / "spe_page_pac.py"
PAC_TO_INTERC = _SHARE_DIR / "pac_to_interc.py"


# ============================================================
# NUMA Topology Detection
# ============================================================

def detect_numa_topology():
    """Detect NUMA topology and determine optimal configuration."""
    topology = {
        "nodes": [],
        "distances": [],
        "sockets": [],
        "recommended_nodes": [],
        "recommended_policy": "preferred",
        "recommended_spread": "compact",
    }

    try:
        result = subprocess.run(
            ["numactl", "-H"], capture_output=True, text=True, timeout=10
        )
        lines = result.stdout.strip().split("\n")

        for line in lines:
            if line.startswith("node ") and "size" in line:
                parts = line.split()
                node_id = int(parts[1])
                mem_mb = int(parts[3])
                topology["nodes"].append({
                    "id": node_id,
                    "mem_mb": mem_mb,
                })
            elif line.startswith("node distances:"):
                # Parse distance matrix
                idx = lines.index(line) + 1
                while idx < len(lines) and lines[idx].startswith("node "):
                    dist_parts = lines[idx].split(":")
                    if len(dist_parts) == 2:
                        row = [int(x) for x in dist_parts[1].split()]
                        topology["distances"].append(row)
                    idx += 1
    except Exception as e:
        print(f"Warning: NUMA detection failed: {e}", file=sys.stderr)

    # Group nodes by socket (distance 10-12 = same socket, 30+ = cross-socket)
    if topology["distances"]:
        n = len(topology["nodes"])
        visited = set()
        sockets = []
        for i in range(n):
            if i in visited:
                continue
            socket_nodes = [i]
            visited.add(i)
            for j in range(i + 1, n):
                if j not in visited and topology["distances"][i][j] <= 20:
                    socket_nodes.append(j)
                    visited.add(j)
            sockets.append(socket_nodes)
        topology["sockets"] = sockets

        # Use ALL nodes — interc auto-selects batch vs per-thread based on topology
        topology["recommended_nodes"] = [n["id"] for n in topology["nodes"]]
        topology["recommended_policy"] = "preferred"
        topology["recommended_spread"] = "auto"  # let interc decide

    return topology


def get_optimal_config(topology):
    """Generate optimal KUMF environment variables based on topology."""
    nodes = topology.get("recommended_nodes", [])
    if not nodes:
        nodes = [n["id"] for n in topology.get("nodes", [])]

    return {
        "KUMF_NODES": ",".join(str(n) for n in nodes),
        # Don't set KUMF_AFFINITY — interc auto-selects batch vs per-thread
        # Don't set KUMF_POLICY — preferred is the correct default for per-thread
    }


# ============================================================
# Daemon Server
# ============================================================

class KumfDaemon:
    """KUMF daemon: manages per-process NUMA optimization."""

    def __init__(self, socket_path=DEFAULT_SOCK, state_dir=DEFAULT_STATE_DIR):
        self.socket_path = socket_path
        self.state_dir = Path(state_dir)
        self.state_dir.mkdir(parents=True, exist_ok=True)
        self.pid_file = DEFAULT_PID_FILE
        self.topology = detect_numa_topology()
        self.optimal_config = get_optimal_config(self.topology)
        self.registered_procs = {}  # pid -> info
        self.profiles = {}  # cmd_hash -> profile data
        self.running = True
        self.sock = None

    def start(self, foreground=False):
        """Start the daemon."""
        # Check if already running
        if self._is_running():
            print(f"KUMF daemon already running (PID {self._read_pid()})")
            return 0

        # Clean up stale socket
        if os.path.exists(self.socket_path):
            os.unlink(self.socket_path)

        if foreground:
            return self._run()
        else:
            # Daemonize
            pid = os.fork()
            if pid > 0:
                # Parent: wait for daemon to start
                time.sleep(0.5)
                if self._is_running():
                    print(f"KUMF daemon started (PID {self._read_pid()})")
                    return 0
                else:
                    print("KUMF daemon failed to start", file=sys.stderr)
                    return 1
            # Child: become daemon
            os.setsid()
            pid2 = os.fork()
            if pid2 > 0:
                os._exit(0)

            # Redirect stdio
            devnull = os.open(os.devnull, os.O_RDWR)
            os.dup2(devnull, 0)
            os.dup2(devnull, 1)
            os.dup2(devnull, 2)
            os.close(devnull)

            return self._run()

    def _run(self):
        """Main daemon loop."""
        # Write PID file
        with open(self.pid_file, 'w') as f:
            f.write(str(os.getpid()))

        # Save topology
        topo_path = self.state_dir / "topology.json"
        with open(topo_path, 'w') as f:
            json.dump(self.topology, f, indent=2)

        # Save optimal config
        config_path = self.state_dir / "auto_config.json"
        with open(config_path, 'w') as f:
            json.dump(self.optimal_config, f, indent=2)

        # Create Unix domain socket
        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
        self.sock.bind(self.socket_path)
        self.sock.settimeout(1.0)

        # Signal handler
        def handle_signal(signum, frame):
            self.running = False

        signal.signal(signal.SIGTERM, handle_signal)
        signal.signal(signal.SIGINT, handle_signal)

        # Main loop
        while self.running:
            try:
                data, addr = self.sock.recvfrom(4096)
                msg = data.decode('utf-8', errors='replace')
                response = self._handle_message(msg)
                if response and addr:
                    self.sock.sendto(response.encode(), addr)
            except socket.timeout:
                continue
            except Exception as e:
                if self.running:
                    print(f"Daemon error: {e}", file=sys.stderr)

        # Cleanup
        self.sock.close()
        os.unlink(self.socket_path) if os.path.exists(self.socket_path) else None
        os.unlink(self.pid_file) if os.path.exists(self.pid_file) else None

        return 0

    def _handle_message(self, msg):
        """Handle incoming daemon messages."""
        parts = msg.split(":", 2)
        cmd = parts[0] if parts else ""

        if cmd == "REG":
            # Process registration: REG:pid:node_count
            pid = int(parts[1]) if len(parts) > 1 else 0
            node_count = int(parts[2]) if len(parts) > 2 else 0
            self.registered_procs[pid] = {
                "pid": pid,
                "node_count": node_count,
                "registered_at": datetime.now().isoformat(),
            }
            return "OK:REG"

        elif cmd == "DEREG":
            pid = int(parts[1]) if len(parts) > 1 else 0
            self.registered_procs.pop(pid, None)
            return "OK:DEREG"

        elif cmd == "STATUS":
            return json.dumps({
                "daemon_pid": os.getpid(),
                "topology": {
                    "nodes": len(self.topology["nodes"]),
                    "sockets": len(self.topology.get("sockets", [])),
                },
                "optimal_config": self.optimal_config,
                "registered_processes": len(self.registered_procs),
                "profiles": len(self.profiles),
            })

        elif cmd == "CONFIG":
            # Return optimal config for a process
            return json.dumps(self.optimal_config)

        elif cmd == "WRAP":
            # Return LD_PRELOAD environment for wrapping a process
            env = {
                "LD_PRELOAD": str(INTERC_SO),
                **self.optimal_config,
            }
            # Check if we have a profile for this command
            if len(parts) > 1:
                cmd_hash = hashlib.md5(parts[1].encode()).hexdigest()[:8]
                profile_path = self.state_dir / f"profile_{cmd_hash}.conf"
                if profile_path.exists():
                    env["KUMF_CONF"] = str(profile_path)

            env["KUMF_DAEMON"] = self.socket_path
            return json.dumps(env)

        elif cmd == "LOOKUP":
            # interc startup query: LOOKUP:pid:exe_path
            exe_path = parts[2] if len(parts) > 2 else ""
            exe_hash = hashlib.md5(exe_path.encode()).hexdigest()[:8]
            lookup_path = self.state_dir / f"lookup_{exe_hash}.conf"
            if lookup_path.exists():
                nodes = ",".join(str(n["id"]) for n in self.topology.get("nodes", []))
                return f"CONFIG:{nodes}:{lookup_path}"
            return "NOCONFIG"

        elif cmd == "PING":
            return "PONG"

        return "ERR:UNKNOWN"

    def stop(self):
        """Stop the daemon."""
        pid = self._read_pid()
        if not pid:
            print("KUMF daemon is not running")
            return 1

        try:
            os.kill(pid, signal.SIGTERM)
            time.sleep(0.5)
            if self._is_running():
                os.kill(pid, signal.SIGKILL)
            print(f"KUMF daemon stopped (PID {pid})")
            return 0
        except ProcessLookupError:
            print("KUMF daemon process not found (cleaning up)")
            self._cleanup()
            return 0

    def status(self):
        """Show daemon status."""
        pid = self._read_pid()
        if not pid:
            print("KUMF daemon: not running")
            return 1

        try:
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
            sock.settimeout(2.0)
            # MUST bind client addr for AF_UNIX DGRAM — otherwise daemon
            # cannot send response back (recvfrom returns empty addr)
            client_addr = f"/tmp/kumf_status_{os.getpid()}"
            if os.path.exists(client_addr):
                os.unlink(client_addr)
            sock.bind(client_addr)
            sock.sendto(b"STATUS", self.socket_path)
            data, _ = sock.recvfrom(4096)
            sock.close()
            os.unlink(client_addr)

            status = json.loads(data.decode())
            topo = status.get("topology", {})
            config = status.get("optimal_config", {})

            print(f"KUMF daemon: running (PID {status['daemon_pid']})")
            print(f"  NUMA: {topo.get('nodes', '?')} nodes, {topo.get('sockets', '?')} sockets")
            print(f"  Optimal config:")
            for k, v in config.items():
                print(f"    {k}={v}")
            print(f"  Registered processes: {status.get('registered_processes', 0)}")
            print(f"  Profiles: {status.get('profiles', 0)}")
            return 0
        except Exception as e:
            print(f"KUMF daemon: running (PID {pid}) but not responding: {e}")
            return 1

    def wrap(self, cmd):
        """Wrap a command with KUMF optimization."""
        if not INTERC_SO.exists():
            print(f"Error: {INTERC_SO} not found (run: make libs)", file=sys.stderr)
            return 1

        # Get config from daemon or use auto-detected config
        env_overrides = {}
        daemon_running = self._is_running()

        if daemon_running:
            try:
                sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
                sock.settimeout(2.0)
                client_addr = f"/tmp/kumf_wrap_{os.getpid()}"
                if os.path.exists(client_addr):
                    os.unlink(client_addr)
                sock.bind(client_addr)
                sock.sendto(f"WRAP:{json.dumps(cmd)}".encode(), self.socket_path)
                data, _ = sock.recvfrom(4096)
                sock.close()
                os.unlink(client_addr)
                env_overrides = json.loads(data.decode())
            except Exception:
                # Fallback to local config
                env_overrides = {
                    "LD_PRELOAD": str(INTERC_SO),
                    **self.optimal_config,
                }
        else:
            # Auto-detect locally — just set LD_PRELOAD + KUMF_NODES
            env_overrides = {
                "LD_PRELOAD": str(INTERC_SO),
                "KUMF_NODES": ",".join(str(n["id"]) for n in self.topology["nodes"]),
            }

        # Execute wrapped command
        env = os.environ.copy()
        env.update(env_overrides)

        # Append to existing LD_PRELOAD if any
        existing_preload = os.environ.get("LD_PRELOAD", "")
        if existing_preload:
            env["LD_PRELOAD"] = f"{env_overrides.get('LD_PRELOAD', '')}:{existing_preload}"

        print(f"🚀 KUMF wrapping: {' '.join(cmd)}")
        if env_overrides.get("KUMF_AFFINITY"):
            print(f"   Affinity: {env_overrides.get('KUMF_AFFINITY')}")
        if env_overrides.get("KUMF_NODES"):
            print(f"   Nodes: {env_overrides.get('KUMF_NODES')}")
        if env_overrides.get("KUMF_POLICY"):
            print(f"   Policy: {env_overrides.get('KUMF_POLICY')}")
        if env_overrides.get("KUMF_CONF"):
            print(f"   Config: {env_overrides.get('KUMF_CONF')}")
        print()

        try:
            result = subprocess.run(cmd, env=env)
            return result.returncode
        except KeyboardInterrupt:
            return 130

    def profile(self, cmd, min_lat=32, period=0, user_only=False, output_dir=None):
        """Profile a workload and generate optimal config."""
        if not INTERC_SO.exists():
            print(f"Error: {INTERC_SO} not found (run: make libs)", file=sys.stderr)
            return 1

        if not PROF_SO.exists():
            print(f"Error: {PROF_SO} not found (run: make libs)", file=sys.stderr)
            return 1

        cmd_hash = hashlib.md5(json.dumps(cmd).encode()).hexdigest()[:8]
        exe_path = os.path.realpath(cmd[0]) if cmd else None  # resolve symlinks to match /proc/self/exe
        if not output_dir:
            output_dir = self.state_dir / f"profile_{cmd_hash}"
        output_dir = Path(output_dir)
        output_dir.mkdir(parents=True, exist_ok=True)

        print(f"╔══════════════════════════════════════════════════╗")
        print(f"║       KUMF Auto-Profile                          ║")
        print(f"╚══════════════════════════════════════════════════╝")
        print()

        # Step 1: Baseline run with affinity only
        print("── Step 1/3: Baseline (affinity only) ──────────────")
        env = os.environ.copy()
        env["LD_PRELOAD"] = str(INTERC_SO)
        env["KUMF_NODES"] = ",".join(str(n) for n in self.optimal_config.get("KUMF_NODES", "").split(",") if n)

        t0 = time.time()
        result = subprocess.run(cmd, env=env, capture_output=True, timeout=600)
        baseline_time = time.time() - t0
        print(f"   Baseline: {baseline_time:.2f}s (exit={result.returncode})")
        print()

        # Step 2: Profile with SPE
        print("── Step 2/3: SPE Profiling ────────────────────────")
        spe_data = output_dir / "spe.perf"
        os.makedirs("/tmp/kumf", exist_ok=True)

        env_prof = os.environ.copy()
        env_prof["LD_PRELOAD"] = str(PROF_SO)

        # Build SPE event with sampling parameters
        spe_params = ["load_filter=1", "store_filter=1"]
        spe_params.append(f"min_latency={min_lat}")
        if period > 0:
            spe_params.append(f"period={period}")

        # Try user-only filter first, retry without if kernel doesn't support it
        spe_event_templates = []
        if user_only:
            spe_event_templates.append(f"arm_spe/{','.join(spe_params + ['filter_el=1'])}/")
        spe_event_templates.append(f"arm_spe/{','.join(spe_params)}/")

        perf_cmd = ["perf", "record"]
        spe_event = spe_event_templates[-1]  # fallback

        t0 = time.time()
        spe_data_path = str(spe_data)
        profiling_attempted = False

        for template in spe_event_templates:
            spe_event = template
            perf_cmd = ["perf", "record", "-e", spe_event, "-o", spe_data_path, "--"] + cmd

            try:
                result = subprocess.run(perf_cmd, env=env_prof, timeout=600,
                                       capture_output=True)
                profiling_attempted = True
                if result.returncode == 0 and spe_data.exists():
                    break
                elif result.returncode != 0 and template != spe_event_templates[-1]:
                    # Kernel doesn't support this SPE config → try fallback
                    print(f"   SPE {template} failed, trying fallback...")
                    if spe_data.exists():
                        spe_data.unlink()
                    continue
                else:
                    break
            except Exception as e:
                profiling_attempted = True
                if template != spe_event_templates[-1]:
                    print(f"   SPE {template} failed ({e}), trying fallback...")
                    if spe_data.exists():
                        spe_data.unlink()
                    continue
                raise

        profile_time = time.time() - t0

        # Diagnostic: show what perf produced
        _stderr = result.stderr.decode('utf-8', errors='replace') if result.stderr else ''
        if _stderr.strip():
            # perf usually outputs to stderr
            perf_lines = [l for l in _stderr.strip().split('\n') if '[ perf record:' in l or 'samples' in l.lower()]
            if perf_lines:
                for l in perf_lines[:3]:
                    print(f"   perf: {l.strip()}")

        if not profiling_attempted or not spe_data.exists():
            print(f"   Profiling failed — SPE may not be available on this platform")
            print(f"   perf stderr: {_stderr[:300] if _stderr else '(none)'}")
            print()
            print("✅ Baseline config saved (affinity-only mode)")
            conf_path = output_dir / "kumf.conf"
            conf_path.write_text("# KUMF auto-config: affinity only (no SPE data)\n")
            self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
            return 0

        import os as _os2
        _st = _os2.stat(str(spe_data))
        print(f"   Profiled: {profile_time:.2f}s (event={spe_event}), spe.perf={_st.st_size / (1024*1024):.1f} MB")
        print()

        # Step 3: Analyze SPE → generate config
        print("── Step 3/3: Analysis → Config ────────────────────")
        # Verify data by trying perf report (st_size can be stale on some FS)
        if not spe_data.exists():
            print(f"   ⚠️  SPE data missing: {spe_data}")
            print()
            print("✅ Baseline config saved (affinity-only mode)")
            conf_path = output_dir / "kumf.conf"
            conf_path.write_text("# KUMF auto-config: affinity only (SPE data missing)\n")
            self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
            return 0

        import os as _os
        _st = _os.stat(str(spe_data))
        print(f"   SPE data: {_st.st_size / (1024*1024):.1f} MB ({spe_data})")
        pac_csv = output_dir / "page_pac.csv"
        raw_file = output_dir / "spe_raw.txt"

        # Parallel dump: split by CPU for speed (ARM SPE is per-CPU)
        if spe_data.stat().st_size < 10 * 1024 * 1024:  # < 10MB: simple path
            with open(raw_file, 'wb') as f:
                rc_dump = subprocess.run(
                    ["perf", "report", "-D", "--no-demangle", "-i", str(spe_data)],
                    stdout=f, stderr=subprocess.PIPE
                )
            if rc_dump.returncode != 0 or raw_file.stat().st_size == 0:
                stderr_text = rc_dump.stderr.decode('utf-8', errors='replace') if rc_dump.stderr else ''
                print(f"   ❌ perf report failed (rc={rc_dump.returncode}): {stderr_text[:200]}")
                raw_file.unlink(missing_ok=True)
                print()
                print("✅ Baseline config saved (affinity-only mode)")
                conf_path = output_dir / "kumf.conf"
                conf_path.write_text("# KUMF auto-config: affinity only (perf report failed)\n")
                self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
                return 0
        else:
            # Per-CPU parallel dump: each CPU's SPE stream is independent
            import os as _os_cpus
            ncpus = _os_cpus.cpu_count() or 120
            print(f"   Parallel dump: splitting by {ncpus} CPUs...")
            cpu_chunks = []
            for cpu in range(min(ncpus, 256)):
                chunk_file = output_dir / f"spe_cpu_{cpu:03d}.txt"
                cpu_chunks.append((cpu, chunk_file))
            
            # Run perf report -D per CPU in parallel (up to 16 concurrent)
            max_procs = min(16, len(cpu_chunks))
            import threading as _thr
            import queue as _q
            cpu_queue = _q.Queue()
            for c in cpu_chunks:
                cpu_queue.put(c)
            
            errors = []
            def _dump_worker():
                while True:
                    try:
                        cpu, chunk = cpu_queue.get_nowait()
                    except _q.Empty:
                        return
                    try:
                        with open(chunk, 'wb') as f:
                            rc = subprocess.run(
                                ["perf", "report", "-D", "--no-demangle",
                                 "--cpu", str(cpu), "-i", str(spe_data)],
                                stdout=f, stderr=subprocess.PIPE, timeout=300
                            )
                    except Exception as e:
                        errors.append(f"cpu={cpu}: {e}")
            
            workers = [_thr.Thread(target=_dump_worker) for _ in range(max_procs)]
            for w in workers:
                w.start()
            for w in workers:
                w.join()
            
            if errors:
                print(f"   ⚠️  {len(errors)} CPU dumps failed: {errors[:3]}")
            
            # Concatenate all chunks into raw_file
            print(f"   Merging {len(cpu_chunks)} CPU dumps...")
            with open(raw_file, 'wb') as out:
                for cpu, chunk in cpu_chunks:
                    if chunk.exists() and chunk.stat().st_size > 0:
                        with open(chunk, 'rb') as inp:
                            out.write(inp.read())
                        chunk.unlink()  # clean up
            
            if raw_file.stat().st_size == 0:
                # Fallback: single-threaded dump
                print(f"   ⚠️  Per-CPU dump produced no data, falling back to single-threaded")
                with open(raw_file, 'wb') as f:
                    rc_single = subprocess.run(
                        ["perf", "report", "-D", "--no-demangle", "-i", str(spe_data)],
                        stdout=f, stderr=subprocess.PIPE
                    )
                if rc_single.returncode != 0:
                    stderr_text = rc_single.stderr.decode('utf-8', errors='replace') if rc_single.stderr else ''
                    print(f"   ❌ perf report failed (rc={rc_single.returncode}): {stderr_text[:200]}")
                    raw_file.unlink(missing_ok=True)
                    print()
                    print("✅ Baseline config saved (affinity-only mode)")
                    conf_path = output_dir / "kumf.conf"
                    conf_path.write_text("# KUMF auto-config: affinity only (perf report failed)\n")
                    self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
                    return 0
        print(f"   Raw dump: {raw_file.stat().st_size / (1024*1024):.1f} MB")

        # Feed raw dump to spe_page_pac.py (parallel if file available)
        import os as _os_pac
        pac_cmd = [sys.executable, str(SPE_PAGE_PAC), "-i", str(raw_file), "-o", str(output_dir)]
        nproc = _os_pac.cpu_count() or 4
        if nproc > 1:
            pac_cmd += ["-j", str(min(nproc, 8))]  # cap at 8 to avoid memory pressure
        print(f"   Running: {' '.join(pac_cmd)}")
        pac_result = subprocess.run(pac_cmd, capture_output=True)
        stderr_text = pac_result.stderr.decode('utf-8', errors='replace') if pac_result.stderr else ''
        if pac_result.returncode != 0:
            print(f"   ❌ spe_page_pac.py failed (rc={pac_result.returncode})")
            if stderr_text:
                print(f"   stderr: {stderr_text[:500]}")
        elif stderr_text:
            print(f"   PAC output: {stderr_text[:300]}")

            if pac_csv.exists() and pac_csv.stat().st_size > 0:
                prof_files = sorted(Path("/tmp/kumf").glob("data.raw.*"))
                conf_path = output_dir / "kumf.conf"

                interc_cmd = [
                    sys.executable, str(PAC_TO_INTERC),
                    "--pac-csv", str(pac_csv),
                    "--mode", "alloc", "-o", str(conf_path),
                ]
                if prof_files:
                    # Merge all prof files (one per thread) into one
                    merged_prof = output_dir / "prof_merged.log"
                    with open(merged_prof, 'w') as out:
                        for pf in prof_files:
                            with open(pf) as inp:
                                out.write(inp.read())
                    # Insert --prof-log PATH before --mode (at index 4)
                    interc_cmd.insert(4, str(merged_prof))
                    interc_cmd.insert(4, "--prof-log")
                    print(f"   Prof log: {len(prof_files)} files merged → {merged_prof.name}")

                print(f"   Running pac_to_interc.py...")
                rc = subprocess.run(interc_cmd, capture_output=True)
                if rc.returncode != 0:
                    err = rc.stderr.decode('utf-8', errors='replace') if rc.stderr else ''
                    print(f"   ❌ pac_to_interc failed (rc={rc.returncode}): {err[:300]}")
                elif conf_path.exists():
                    nc = subprocess.run(["wc", "-l", str(conf_path)],
                                       capture_output=True)
                    lines = nc.stdout.decode().split()[0]
                    print(f"   ✅ Config: {conf_path} ({lines} lines)")

                    with open(conf_path) as cf:
                        rules = [l.strip() for l in cf if l.strip() and not l.startswith('#')]
                    if rules:
                        print(f"   Rules: {len(rules)}")
                        for r in rules[:5]:
                            print(f"     {r}")
                    else:
                        print("   ⚠️  Config has no rules — PAC found no actionable hot pages")

                    self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
                else:
                    print("   ⚠️  Config not generated")
                    conf_path = output_dir / "kumf.conf"
                    conf_path.write_text("# KUMF auto-config: pac_to_interc failed\n")
                    self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
            else:
                print(f"   ⚠️  No PAC data (csv exists={pac_csv.exists()}, size={pac_csv.stat().st_size if pac_csv.exists() else 0})")
                if raw_file.exists():
                    lcount = subprocess.run(["wc", "-l", str(raw_file)],
                                           capture_output=True)
                    lines = lcount.stdout.decode().split()[0]
                    print(f"   Raw dump: {lines} lines")
                conf_path = output_dir / "kumf.conf"
                conf_path.write_text(
                    "# KUMF auto-config: affinity only (PAC found no hot pages)\n"
                    "# Tip: try --min-lat 32 to capture more L3-access data\n"
                )
                self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
        else:
            # spe_page_pac ran OK but produced no stderr output
            # → no PAC hot pages found, save affinity-only baseline
            print(f"   ⚠️  PAC found no hot pages (empty output)")
            print()
            print("✅ Baseline config saved (affinity-only mode)")
            conf_path = output_dir / "kumf.conf"
            conf_path.write_text(
                "# KUMF auto-config: affinity only (PAC found no hot pages)\n"
                "# Tip: try --min-lat 32 to capture more L3-access data\n"
            )
            self._save_profile(cmd_hash, str(conf_path), baseline_time, exe_path=exe_path)
            return 0

        print()
        print(f"✅ Profile saved for: {' '.join(cmd)}")
        print(f"   Baseline: {baseline_time:.2f}s")
        return 0

    def _save_profile(self, cmd_hash, conf_path, baseline_time, exe_path=None):
        """Save profile to daemon state and register for transparent lookup."""
        profile = {
            "cmd_hash": cmd_hash,
            "conf_path": conf_path,
            "baseline_time": baseline_time,
            "profiled_at": datetime.now().isoformat(),
        }
        if exe_path:
            profile["exe_path"] = exe_path
        self.profiles[cmd_hash] = profile

        # Persist to disk
        profile_path = self.state_dir / f"profile_{cmd_hash}.json"
        with open(profile_path, 'w') as f:
            json.dump(profile, f, indent=2)

        # Symlink config for WRAP command
        link_path = self.state_dir / f"profile_{cmd_hash}.conf"
        try:
            if link_path.exists() or link_path.is_symlink():
                link_path.unlink()
            link_path.symlink_to(conf_path)
        except Exception:
            import shutil
            shutil.copy2(conf_path, link_path)

        # Register by exe_path for transparent LOOKUP queries
        if exe_path:
            exe_hash = hashlib.md5(exe_path.encode()).hexdigest()[:8]
            lookup_path = self.state_dir / f"lookup_{exe_hash}.conf"
            try:
                if lookup_path.exists() or lookup_path.is_symlink():
                    lookup_path.unlink()
                lookup_path.symlink_to(conf_path)
            except Exception:
                import shutil
                shutil.copy2(conf_path, lookup_path)

    def _is_running(self):
        """Check if daemon is running."""
        pid = self._read_pid()
        if not pid:
            return False
        try:
            os.kill(pid, 0)
            return True
        except ProcessLookupError:
            self._cleanup()
            return False

    def _read_pid(self):
        """Read PID file."""
        try:
            with open(self.pid_file, 'r') as f:
                return int(f.read().strip())
        except (FileNotFoundError, ValueError):
            return None

    def _cleanup(self):
        """Clean up stale files."""
        for path in [self.pid_file, self.socket_path]:
            try:
                if os.path.exists(path):
                    os.unlink(path)
            except Exception:
                pass


