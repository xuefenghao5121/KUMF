#!/usr/bin/env python3
"""
kumf - Kunpeng Unified Memory Framework CLI

形态1: 一键诊断 → 报告 + 配置
形态2: 透明加速 → daemon 自动管理
形态3: 手动运行 → LD_PRELOAD 注入

用法:
  kumf daemon start [--foreground]   # 启动守护进程
  kumf daemon status                 # 查看状态
  kumf daemon wrap -- ./workload     # 无感知运行（自动优化）
  kumf daemon profile -- ./workload  # 采样+生成配置
  kumf diagnose -- ./workload        # 一键诊断
  kumf run [--conf FILE] -- ./workload  # 手动指定配置运行
  kumf bench -- ./workload           # 性能对比
  kumf config                        # 显示自动检测的最优配置
"""

import sys
import os
import subprocess
import argparse
from pathlib import Path

# ─── Path resolution: source tree vs installed ───
def _resolve_kumf_dirs():
    env_home = os.environ.get("KUMF_HOME")
    if env_home:
        return Path(env_home) / "lib", Path(env_home) / "share"
    script_dir = Path(os.path.realpath(__file__)).parent
    src_root = script_dir.parent
    if (src_root / "build").is_dir() and (src_root / "src" / "lib" / "interc").is_dir():
        return src_root / "build", src_root / "tools"
    return src_root / "lib" / "kumf", src_root / "share" / "kumf"

KUMF_ROOT = Path(__file__).resolve().parent.parent
TOOLS_DIR = Path(__file__).resolve().parent
_LIB_DIR, _SHARE_DIR = _resolve_kumf_dirs()


def main():
    parser = argparse.ArgumentParser(
        prog="kumf",
        description="KUMF - Kunpeng Unified Memory Framework"
    )
    sub = parser.add_subparsers(dest="command", help="Available commands")

    # daemon (delegate to kumf_daemon)
    p_daemon = sub.add_parser("daemon", help="Manage KUMF daemon (transparent optimization)")
    p_daemon.add_argument("daemon_args", nargs=argparse.REMAINDER,
                          help="Daemon subcommand: start|stop|status|wrap|profile|config|autostart|shell-init")

    # diagnose
    p_diag = sub.add_parser("diagnose", help="一键诊断：采样→分析→报告+配置")
    p_diag.add_argument("--min-lat", type=int, default=32, help="SPE min_latency filter (default: 32)")
    p_diag.add_argument("-o", "--output", default="/tmp/kumf", help="Output directory")
    p_diag.add_argument("workload", help="Workload binary")
    p_diag.add_argument("workload_args", nargs="*", help="Workload arguments")

    # run
    p_run = sub.add_parser("run", help="用 interc 配置运行 workload")
    p_run.add_argument("--conf", "-c", default=None, help="interc config file")
    p_run.add_argument("--debug", action="store_true", help="Enable KUMF debug output")
    p_run.add_argument("--affinity", default=None, help="Affinity mode: auto|compact|off")
    p_run.add_argument("--nodes", default=None, help="NUMA nodes (comma-separated)")
    p_run.add_argument("--policy", default=None, help="Memory policy: preferred|bind|interleave")
    p_run.add_argument("workload", help="Workload binary")
    p_run.add_argument("workload_args", nargs="*", help="Workload arguments")

    # analyze
    p_analyze = sub.add_parser("analyze", help="只分析已有的 perf.data")
    p_analyze.add_argument("--perf-data", default="perf.data", help="perf.data file")
    p_analyze.add_argument("-o", "--output", default="/tmp/kumf", help="Output directory")

    # bench
    p_bench = sub.add_parser("bench", help="性能对比：全快/全慢/first-touch/分层")
    p_bench.add_argument("--conf", "-c", default=None, help="interc config file")
    p_bench.add_argument("-o", "--output", default="/tmp/kumf", help="Output directory for results")
    p_bench.add_argument("--runs", type=int, default=1, help="Number of runs per config")
    p_bench.add_argument("workload", help="Workload binary")
    p_bench.add_argument("workload_args", nargs="*", help="Workload arguments")

    # config
    sub.add_parser("config", help="显示自动检测的最优配置")

    args = parser.parse_args()

    if args.command == "daemon":
        # Delegate to kumf_daemon
        daemon_script = TOOLS_DIR / "kumf_daemon"
        if not daemon_script.exists():
            print(f"Error: {daemon_script} not found", file=sys.stderr)
            return 1
        daemon_cmd = [sys.executable, str(daemon_script)] + (args.daemon_args or [])
        result = subprocess.run(daemon_cmd)
        return result.returncode

    elif args.command == "diagnose":
        return cmd_diagnose(args)
    elif args.command == "run":
        return cmd_run(args)
    elif args.command == "analyze":
        return cmd_analyze(args)
    elif args.command == "bench":
        return cmd_bench(args)
    elif args.command == "config":
        return cmd_config()
    else:
        parser.print_help()
        return 1


# ============================================================
# kumf config — show auto-detected optimal config
# ============================================================

def cmd_config():
    """Show auto-detected NUMA topology and optimal KUMF configuration."""
    daemon_script = TOOLS_DIR / "kumf_daemon"
    result = subprocess.run([sys.executable, str(daemon_script), "config"])
    return result.returncode


# ============================================================
# kumf diagnose
# ============================================================

def cmd_diagnose(args):
    """一键诊断：自动采样 → 分析 → 报告 + 配置"""
    import json
    import shutil
    import time

    SPE_PAGE_PAC = TOOLS_DIR / "spe_page_pac.py"
    PAC_TO_INTERC = TOOLS_DIR / "pac_to_interc.py"
    INTERC_SO = _LIB_DIR / "libkumf_interc.so"
    PROF_SO = _LIB_DIR / "libkumf_prof.so"

    print("╔══════════════════════════════════════════════════╗")
    print("║       KUMF Tiered Memory Diagnosis               ║")
    print("║       Kunpeng Unified Memory Framework            ║")
    print("╚══════════════════════════════════════════════════╝")
    print()

    # 1. 环境检查
    print("── Step 0/4: Environment Check ──────────────────────")
    issues = []
    if not shutil.which("perf"):
        issues.append("perf not found")
    if not INTERC_SO.exists():
        issues.append(f"{INTERC_SO} not found (run: make libs)")
    if not PROF_SO.exists():
        issues.append(f"{PROF_SO} not found (run: make libs)")

    try:
        result = subprocess.run(["perf", "list"], capture_output=True, text=True, timeout=5)
        if "arm_spe" not in result.stdout:
            issues.append("ARM SPE not available (need ARM platform with SPE)")
    except Exception:
        pass

    if issues:
        print("❌ Issues:")
        for i in issues:
            print(f"   - {i}")
        return 1
    print("✅ All tools available")
    print()

    # NUMA topology
    try:
        result = subprocess.run(["numactl", "-H"], capture_output=True, text=True, timeout=10)
        for line in result.stdout.strip().split("\n"):
            if "size" in line:
                print(f"   {line.strip()}")
    except Exception:
        pass
    print()

    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    workload = args.workload
    workload_args = args.workload_args
    spe_data = output_dir / "spe.perf"

    # 2. SPE + prof 采样
    print("── Step 1/4: SPE Sampling + Prof Tracking ──────────")
    print(f"   Workload: {' '.join([workload] + workload_args)}")
    print(f"   SPE filter: min_latency={args.min_lat}")
    print()

    spe_event = f"arm_spe/load_filter=1,store_filter=1,min_latency={args.min_lat}/"
    os.makedirs("/tmp/kumf", exist_ok=True)

    env = os.environ.copy()
    env["LD_PRELOAD"] = str(PROF_SO)

    perf_cmd = ["perf", "record", "-e", spe_event, "-o", str(spe_data), "--"] + [workload] + workload_args

    print(f"   Running: {' '.join(perf_cmd[:6])}...")
    t0 = time.time()
    try:
        result = subprocess.run(perf_cmd, env=env, timeout=600)
        elapsed = time.time() - t0
        print(f"✅ Sampling done ({elapsed:.1f}s)")
    except subprocess.TimeoutExpired:
        print("❌ Workload timed out")
        return 1
    print()

    if not spe_data.exists():
        print("❌ No SPE data captured")
        return 1

    # 3. 解析 SPE → page PAC
    print("── Step 2/4: SPE LAT → Page PAC Scoring ────────────")
    pac_csv = output_dir / "page_pac.csv"

    t0 = time.time()
    try:
        proc_report = subprocess.Popen(
            ["perf", "report", "-D", "-i", str(spe_data)],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE
        )
        proc_pac = subprocess.Popen(
            [sys.executable, str(SPE_PAGE_PAC), "-o", str(output_dir)],
            stdin=proc_report.stdout, stdout=sys.stdout, stderr=sys.stderr
        )
        proc_report.stdout.close()
        proc_pac.wait()
        print(f"✅ PAC analysis done ({time.time()-t0:.1f}s)")
    except Exception as e:
        print(f"❌ PAC analysis failed: {e}")
        return 1
    print()

    # 4. PAC + prof → interc 配置
    print("── Step 3/4: PAC + Prof → interc Config ────────────")
    conf_path = output_dir / "kumf.conf"
    prof_files = sorted(Path("/tmp/kumf").glob("data.raw.*"))

    if prof_files and pac_csv.exists():
        interc_cmd = [
            sys.executable, str(PAC_TO_INTERC),
            "--pac-csv", str(pac_csv),
            "--prof-log", str(prof_files[0]),
            "--mode", "alloc", "-o", str(conf_path),
        ]
        result = subprocess.run(interc_cmd, capture_output=True, text=True)
        if result.returncode != 0:
            interc_cmd = [
                sys.executable, str(PAC_TO_INTERC),
                "--pac-csv", str(pac_csv),
                "--mode", "size", "-o", str(conf_path),
            ]
            result = subprocess.run(interc_cmd, capture_output=True, text=True)
    elif pac_csv.exists():
        interc_cmd = [
            sys.executable, str(PAC_TO_INTERC),
            "--pac-csv", str(pac_csv),
            "--mode", "size", "-o", str(conf_path),
        ]
        result = subprocess.run(interc_cmd, capture_output=True, text=True)

    print(f"✅ Config generated: {conf_path}")
    print()

    # 5. 报告
    print("── Step 4/4: Diagnosis Report ──────────────────────")
    report_path = output_dir / "pac_summary.txt"
    if report_path.exists():
        with open(report_path, 'r') as f:
            for line in f:
                if any(kw in line for kw in ["HOT", "WARM", "COLD", "local", "remote"]):
                    print(f"   {line.strip()}")

    print()
    print(f"  Run optimized: kumf daemon wrap -- {' '.join([workload] + workload_args)}")
    print(f"  Run manually:  kumf run --conf {conf_path} -- {' '.join([workload] + workload_args)}")
    return 0


# ============================================================
# kumf run
# ============================================================

def cmd_run(args):
    """用 interc 配置运行 workload"""
    INTERC_SO = _LIB_DIR / "libkumf_interc.so"

    if not INTERC_SO.exists():
        print(f"Error: {INTERC_SO} not found (run: make libs)", file=sys.stderr)
        return 1

    env = os.environ.copy()

    # Layer 2: config-driven routing
    if args.conf and os.path.exists(args.conf):
        env["KUMF_CONF"] = os.path.abspath(args.conf)

    # Layer 1: affinity settings
    if args.affinity:
        env["KUMF_AFFINITY"] = args.affinity
    if args.nodes:
        env["KUMF_NODES"] = args.nodes
    if args.policy:
        env["KUMF_POLICY"] = args.policy

    if args.debug:
        env["KUMF_DEBUG"] = "1"

    env["LD_PRELOAD"] = str(INTERC_SO)

    cmd = [args.workload] + args.workload_args
    print(f"🚀 KUMF running")
    if args.conf:
        print(f"   Config: {args.conf}")
    print(f"   Affinity: {env.get('KUMF_AFFINITY', 'auto')}")
    print(f"   Nodes: {env.get('KUMF_NODES', 'auto')}")
    print(f"   Policy: {env.get('KUMF_POLICY', 'preferred')}")
    print()

    try:
        result = subprocess.run(cmd, env=env)
        return result.returncode
    except KeyboardInterrupt:
        return 130


# ============================================================
# kumf analyze
# ============================================================

def cmd_analyze(args):
    """只分析已有的 perf.data"""
    SPE_PAGE_PAC = TOOLS_DIR / "spe_page_pac.py"
    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    print(f"🦐 KUMF Analyze: {args.perf_data}")

    try:
        proc_report = subprocess.Popen(
            ["perf", "report", "-D", "-i", args.perf_data],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE
        )
        proc_pac = subprocess.Popen(
            [sys.executable, str(SPE_PAGE_PAC), "-o", str(output_dir)],
            stdin=proc_report.stdout, stdout=sys.stdout, stderr=sys.stderr
        )
        proc_report.stdout.close()
        proc_pac.wait()
        print(f"✅ Done. Output in {output_dir}")
        return 0
    except Exception as e:
        print(f"❌ Analysis failed: {e}")
        return 1


# ============================================================
# kumf bench
# ============================================================

def cmd_bench(args):
    """性能对比"""
    import json
    from datetime import datetime

    INTERC_SO = _LIB_DIR / "libkumf_interc.so"
    workload = args.workload
    workload_args = args.workload_args
    runs = args.runs

    results = {}

    def run_test(name, cmd, env=None):
        times = []
        for i in range(runs):
            label = f"{name}" if runs == 1 else f"{name} ({i+1}/{runs})"
            print(f"  {label}...", end=" ", flush=True)
            t0 = time.time()
            try:
                subprocess.run(cmd, env=env, capture_output=True, timeout=600)
                elapsed = time.time() - t0
                times.append(elapsed)
                print(f"{elapsed:.2f}s")
            except Exception as e:
                print(f"FAILED ({e})")

        if times:
            avg = sum(times) / len(times)
            variance = sum((t - avg) ** 2 for t in times) / len(times) if len(times) > 1 else 0
            std = variance ** 0.5
            results[name] = {"avg": avg, "std": std, "times": times, "runs": len(times)}

    import time

    print()
    print("── KUMF Performance Benchmark ────────────────────")
    print(f"   Workload: {' '.join([workload] + workload_args)}")
    print(f"   Runs per config: {runs}")
    print()

    # 1. Affinity-only (Layer 1, recommended)
    if INTERC_SO.exists():
        env = os.environ.copy()
        env["LD_PRELOAD"] = str(INTERC_SO)
        env["KUMF_AFFINITY"] = "compact"
        run_test("KUMF L1 (affinity)", [workload] + workload_args, env=env)

    # 2. KUMF L1+L2 (if config available)
    if args.conf and INTERC_SO.exists():
        env = os.environ.copy()
        env["LD_PRELOAD"] = str(INTERC_SO)
        env["KUMF_AFFINITY"] = "compact"
        env["KUMF_CONF"] = os.path.abspath(args.conf)
        run_test("KUMF L1+L2 (affinity+routing)", [workload] + workload_args, env=env)

    # 3. First-touch baseline
    run_test("First-touch (default)", [workload] + workload_args)

    # 4. numactl comparisons
    run_test("cpunodebind=0,1", ["numactl", "--cpunodebind=0,1"] + [workload] + workload_args)
    run_test("cpunodebind=0,1 + membind=0,1",
             ["numactl", "--cpunodebind=0,1", "--membind=0,1"] + [workload] + workload_args)

    # Summary
    print()
    print("── Results ───────────────────────────────────────")
    for name, data in results.items():
        avg = data["avg"]
        std = data["std"]
        if std > 0:
            print(f"  {name:40s} {avg:6.2f}s ± {std:5.2f}s ({data['runs']} runs)")
        else:
            print(f"  {name:40s} {avg:6.2f}s")

    # Save results
    if args.output:
        bench_path = Path(args.output) / "bench_results.json"
        bench_path.parent.mkdir(parents=True, exist_ok=True)
        with open(bench_path, 'w') as f:
            json.dump({
                "timestamp": datetime.now().isoformat(),
                "workload": workload,
                "results": {k: v for k, v in results.items()},
            }, f, indent=2)
        print(f"\n  📊 Results saved: {bench_path}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
